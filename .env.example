# --- Model provider selection ----------------------------------------
# Which backend serves the vision verifier + GPT markdown generator:
#   aoai    → Azure OpenAI (AAD via AzureCliCredential)
#   copilot → Personal GitHub Copilot subscription (OAuth)
DOCEVAL_MODEL_SOURCE=aoai

# Model / deployment id. For aoai this is the Azure deployment name; for
# copilot this is any chat model returned by Copilot's /models endpoint
# (e.g. gpt-5.4, gpt-5.5, claude-opus-4.7, gemini-2.5-pro).
DOCEVAL_MODEL_NAME=gpt-5.4

# Optional override for the vision verifier (the model that adjudicates
# single-source hallucinations). Leave empty to reuse DOCEVAL_MODEL_NAME.
# Handy for using a stronger reasoning model just for verification, e.g.
# DOCEVAL_MODEL_NAME=gpt-5.4 + DOCEVAL_VERIFIER_MODEL=claude-opus-4.7.
DOCEVAL_VERIFIER_MODEL=

# --- Azure OpenAI (used when DOCEVAL_MODEL_SOURCE=aoai) ---------------
DOCEVAL_AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/
DOCEVAL_AZURE_OPENAI_API_VERSION=2025-04-01-preview
# Tenant that owns the Azure OpenAI resource. Pin this so AAD token
# acquisition doesn't accidentally use another tenant (e.g. VS Code's
# signed-in identity from a different org).
DOCEVAL_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# --- GitHub Copilot (used when DOCEVAL_MODEL_SOURCE=copilot) ----------
# ⚠️  Using Copilot outside an IDE editing flow violates GitHub's ToS and
#     risks account suspension. For personal experimentation only.
# Long-lived OAuth token (ghu_…). Leave empty to trigger a one-time
# device-flow login that will write the token back to .env automatically.
COPILOT_OAUTH_TOKEN=

# --- Azure Document Intelligence (OCR) --------------------------------
DOCEVAL_DI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
DOCEVAL_DI_KEY=

# --- Data layout (relative to project root) ---------------------------
DOCEVAL_DATA_ROOT=.
DOCEVAL_OUTPUT_DIR=output
