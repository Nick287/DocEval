# Azure OpenAI (vision verifier) — uses AAD via AzureCliCredential
INTSIG_EVAL_AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/
INTSIG_EVAL_AZURE_OPENAI_DEPLOYMENT=gpt-5.4
INTSIG_EVAL_AZURE_OPENAI_API_VERSION=2025-04-01-preview
# Tenant that owns the Azure OpenAI resource. Pin this so AAD token
# acquisition doesn't accidentally use another tenant (e.g. VS Code's
# signed-in identity from a different org).
INTSIG_EVAL_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Azure Document Intelligence (OCR)
INTSIG_EVAL_DI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
INTSIG_EVAL_DI_KEY=

# Data layout (relative to project root)
INTSIG_EVAL_DATA_ROOT=.
INTSIG_EVAL_OUTPUT_DIR=output
